[
    //! Editor

    //* Lines
    {
        "key": "alt+d",
        "command": "editor.action.deleteLines",
        "when": "editorFocus"
    },
    {
        "key": "tab",
        "command": "editor.action.indentLines",
        "when": "editorFocus && !inlineSuggestionVisible"
    },
    {
        "key": "shift+tab",
        "command": "editor.action.outdentLines",
        "when": "editorFocus && !inlineSuggestionVisible"

    },

    //* Cursor
    {
        "key": "alt+o",
        "command": "editor.action.insertLineBefore",
        "when": "editorFocus"
    },
    {
        "key": "alt+enter",
        "command": "editor.action.insertLineAfter",
        "when": "editorFocus"
    },
    {
        "key": "alt+t",
        "command": "cursorTop",
        "when": "editorFocus"
    },
    {
        "key": "alt+b",
        "command": "cursorBottom",
        "when": "editorFocus"
    },
    {
        "key": "alt+i",
        "command": "cursorLineStart",
        "when": "editorFocus"
    },
    {
        "key": "alt+a",
        "command": "cursorLineEnd",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+k",
        "command": "cursorUpSelect",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+j",
        "command": "cursorDownSelect",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+h",
        "command": "cursorLeftSelect",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+l",
        "command": "cursorRightSelect",
        "when": "editorFocus"
    },
    {
        "key": "alt+h",
        "command": "cursorLeft",
        "when": "editorFocus"
    },
    {
        "key": "alt+j",
        "command": "cursorDown",
        "when": "editorFocus"
    },
    {
        "key": "alt+k",
        "command": "cursorUp",
        "when": "editorFocus"
    },
    {
        "key": "alt+l",
        "command": "cursorRight",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+alt+l",
        "command": "cursorEndSelect",
        "when": "editorFocus"
    },
    {
        "key": "ctrl+alt+h",
        "command": "cursorStartSelect",
        "when": "editorFocus"
    },
    {
        "key": "alt+x",
        "command": "deleteRight",
        "when": "editorFocus"
    },

    //* Widget menu
    {
        "key": "alt+j",
        "command": "selectNextSuggestion",
        "when": "editorFocus && suggestWidgetVisible"
    },
    {
        "key": "alt+k",
        "command": "selectPrevSuggestion",
        "when": "editorFocus && suggestWidgetVisible"
    },
    //* Virtual inline text
    {
        "key": "ctrl+l",
        "command": "editor.action.inlineSuggest.acceptNextWord",
        "when": "editorFocus && inlineSuggestionVisible"
    },

    //! FileExplorer
    {
        "key": "enter",
        "command": "macros.openFileAndCloseExplorer",
        "when": "explorerViewletVisible && explorerViewletFocus"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.view.explorer",
        "when": "!explorerViewletVisible || editorFocus"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.action.closeSidebar",
        "when": "explorerViewletVisible && explorerViewletFocus"
    },
    {
        "key": "alt+h",
        "command": "list.collapse",
        "when": "explorerViewletFocus"
    },
    {
        "key": "alt+j",
        "command": "list.focusDown",
        "when": "explorerViewletFocus"
    },
    {
        "key": "alt+k",
        "command": "list.focusUp",
        "when": "explorerViewletFocus"
    },
    {
        "key": "alt+l",
        "command": "list.expand",
        "when": "explorerViewletFocus"
    },
    {
        "key": "ctrl+a",
        "command": "explorer.newFile",
        "when": "explorerViewletFocus"
    },
    {
        "key": "ctrl+d",
        "command": "moveFileToTrash",
        "when": "explorerViewletFocus"
    },
    {
        "key": "ctrl+r",
        "command": "renameFile",
        "when": "explorerViewletFocus"
    },

    //! Terminal
    {
        "key": "ctrl+'",
        "when": "terminalFocus",
        "command": "workbench.action.terminal.split"
    },
    {
        "key": "ctrl+\\",
        "command": "workbench.action.terminal.new",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.terminal.scrollDown",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.terminal.scrollUp",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001bf" },
        "when": "terminalFocus"
    },
    {
        "key": "alt+l",
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[C" },
        "when": "terminalFocus"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.terminal.next",
        "args": { "text": "\u001b[C" },
        "when": "terminalFocus"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[A" },
        "when": "terminalFocus"
    },
    {
        "key": "alt+j",
        "command": "workbench.action.terminal.sendSequence",
        "args": { "text": "\u001b[B" },
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+h",
        "command": "workbench.action.terminal.focusNextPane",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+l",
        "command": "workbench.action.terminal.focusPreviousPane",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+j",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+alt+k",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus"
    },

    //! Quick open
    {
        "key": "alt+j",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        "key": "alt+k",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    }
]
